{
    "name": "@cbnsndwch/world-gen",
    "description": "Musicologia world generators: WFC (deterministic) and LLM paths producing a WorldSpec",
    "version": "0.0.0",
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org/"
    },
    "type": "module",
    "license": "MIT",
    "author": {
        "name": "Sergio Leon",
        "email": "oss@cbnsndwch.io"
    },
    "scripts": {
        "build": "tsup",
        "format": "oxfmt --write src",
        "lint": "oxlint ./src",
        "lint:fix": "oxlint ./src --fix",
        "typecheck": "tsc --noEmit",
        "test": "vitest --run --passWithNoTests",
        "ci:test": "vitest --run --passWithNoTests --bail 1",
        "test:watch": "vitest",
        "test:coverage": "vitest --coverage"
    },
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@cbnsndwch/contracts": "workspace:*",
        "@cbnsndwch/wfc": "workspace:*",
        "zod": "^3.25.0"
    },
    "devDependencies": {
        "@cbnsndwch/tsconfig": "workspace:*",
        "@types/node": "^22",
        "@vitest/coverage-v8": "^4.1.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.js"
}
