{
    "extends": "@cbnsndwch/tsconfig/base.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"]
        },
        "noEmit": true
    },
    "include": ["src", "vite.config.ts"],
    "exclude": ["node_modules", "dist"]
}
