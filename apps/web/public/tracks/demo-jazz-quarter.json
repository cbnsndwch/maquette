  "lore": {
    "tagline": "A late-night shuffle from the storied back-room of the French Quarter.",
    "story": "The Magnolia Jazz Ensemble cut this live at a narrow club on Frenchmen Street, two nights before Mardi Gras. The recording captures that specific tension between the tightly swung rhythm section and the loose, searching horns.",
    "themes": ["jazz", "new-orleans", "blues", "improvisation"],
    "trivia": [
      "The piano was an out-of-tune upright that hadn't been serviced since the 1970s — kept for character.",
      "Two audience members can be heard laughing at bar 48 of the trumpet solo."
    ]
